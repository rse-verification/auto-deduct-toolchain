#!/usr/bin/env bash

set -euo pipefail

image="${AUTO_DEDUCT_IMAGE:-auto-deduct:latest}"
port="${AUTO_DEDUCT_GUI_PORT:-8765}"
container_path="/project"
project_path="${PWD}"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options] [PROJECT_PATH]

Start the AutoDeduct contract assistant GUI in Docker and mount PROJECT_PATH
so the GUI can run Frama-C directly on the project tree.

Options:
  --image IMAGE           Docker image to run (default: ${image})
  --port PORT             Host port for the browser UI (default: ${port})
  --container-path PATH   Container mount path (default: ${container_path})
  -h, --help              Show this help

Environment:
  AUTO_DEDUCT_IMAGE       Default Docker image
  AUTO_DEDUCT_GUI_PORT    Default host port

Examples:
  scripts/autodeduct-contract-assistant-gui-docker .
  scripts/autodeduct-contract-assistant-gui-docker --port 8781 /path/to/case-study-gms

After startup, open http://127.0.0.1:PORT and enter this in the GUI:
  Project path in container: ${container_path}
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --image)
      if [ "$#" -lt 2 ]; then
        echo "Missing value for --image" >&2
        exit 2
      fi
      image="$2"
      shift 2
      ;;
    --port)
      if [ "$#" -lt 2 ]; then
        echo "Missing value for --port" >&2
        exit 2
      fi
      port="$2"
      shift 2
      ;;
    --container-path)
      if [ "$#" -lt 2 ]; then
        echo "Missing value for --container-path" >&2
        exit 2
      fi
      container_path="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      project_path="$1"
      shift
      if [ "$#" -gt 0 ]; then
        echo "Only one PROJECT_PATH can be mounted." >&2
        usage >&2
        exit 2
      fi
      ;;
  esac
done

if [ ! -d "$project_path" ]; then
  echo "PROJECT_PATH must be an existing directory: $project_path" >&2
  exit 1
fi

project_path="$(cd "$project_path" && pwd -P)"

cat <<EOF
Starting AutoDeduct contract assistant GUI.

Local project path:
  ${project_path}

Container project path:
  ${container_path}

Browser URL:
  http://127.0.0.1:${port}

In the GUI, use:
  Project path in container: ${container_path}
EOF

docker run -it --rm \
  -p "127.0.0.1:${port}:8765" \
  -v "${project_path}:${container_path}" \
  -w "${container_path}" \
  "${image}" \
  /usr/bin/bash -l -c 'autodeduct-contract-assistant-gui --host 0.0.0.0 --port 8765'
