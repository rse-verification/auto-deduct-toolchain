  <script>
    const projectPathInput = document.getElementById("projectPath");
    const framacArgsInput = document.getElementById("framacArgs");
    const includeMain = document.getElementById("includeMain");
    const runButton = document.getElementById("run");
    const generateDraftButton = document.getElementById("generateDraft");
    const runWpDraftButton = document.getElementById("runWpDraft");
    const runEvaButton = document.getElementById("runEva");
    const runWpButton = document.getElementById("runWp");
    const copyPromptButton = document.getElementById("copyPrompt");
    const browseProjectPathButton = document.getElementById("browseProjectPath");
    const useProjectRootButton = document.getElementById("useProjectRoot");
    const pathBrowser = document.getElementById("pathBrowser");
    const statusBox = document.getElementById("status");
    const pipelineBox = document.getElementById("pipeline");
    const summaryBox = document.getElementById("summary");
    const promptBox = document.getElementById("prompt");
    const draftBox = document.getElementById("draft");
    const framacBox = document.getElementById("framac");
    const jsonBox = document.getElementById("json");

    document.querySelectorAll(".tab").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".tab").forEach((tab) => tab.classList.remove("active"));
        button.classList.add("active");
        for (const id of ["summary", "prompt", "draft", "framac", "json"]) {
          document.getElementById(id).classList.toggle("hidden", id !== button.dataset.tab);
        }
      });
    });

    function requestProjectPath() {
      return projectPathInput.value.trim() || "/project";
    }

    function renderPathBrowser(data) {
      pathBrowser.innerHTML = "";
      pathBrowser.classList.remove("hidden");

      const head = document.createElement("div");
      head.className = "path-head";
      head.textContent = `Docker path: ${data.path}`;
      pathBrowser.append(head);

      if (data.parent) {
        const parent = document.createElement("button");
        parent.className = "path-entry";
        parent.innerHTML = "<span>..</span><span>Parent directory</span><span class='path-kind'>dir</span>";
        parent.addEventListener("click", () => browseProjectPath(data.parent));
        pathBrowser.append(parent);
      }

      for (const entry of data.entries) {
        const button = document.createElement("button");
        button.className = "path-entry";
        const icon = entry.is_dir ? "dir" : "src";
        const kind = entry.is_dir ? "dir" : "file";
        button.innerHTML = `<span>${icon}</span><span></span><span class="path-kind">${kind}</span>`;
        button.children[1].textContent = entry.name;
        button.addEventListener("click", () => {
          projectPathInput.value = entry.path;
          if (entry.is_dir) {
            browseProjectPath(entry.path);
          } else {
            statusBox.textContent = `Selected Docker path: ${entry.path}`;
          }
        });
        pathBrowser.append(button);
      }

      if (data.entries.length === 0) {
        const empty = document.createElement("div");
        empty.className = "path-head";
        empty.textContent = "No subdirectories or C/H source files found here.";
        pathBrowser.append(empty);
      }
    }

    async function browseProjectPath(path) {
      const target = path || projectPathInput.value.trim() || "/project";
      statusBox.textContent = `Browsing Docker path ${target}...`;
      try {
        const response = await fetch("/api/list-path", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ project_path: target })
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || "Could not list Docker path");
        projectPathInput.value = data.path;
        renderPathBrowser(data);
        statusBox.textContent = `Showing Docker path ${data.path}.`;
      } catch (error) {
        statusBox.textContent = error.message;
        renderPipeline([{status: "error", name: "Browse Docker path", detail: error.message}]);
      }
    }

    function renderPipeline(steps) {
      pipelineBox.innerHTML = "";
      for (const step of steps) {
        const item = document.createElement("div");
        item.className = "step";
        const badge = document.createElement("div");
        badge.className = "badge " + step.status;
        badge.textContent = step.status.toUpperCase();
        const body = document.createElement("div");
        const title = document.createElement("div");
        title.className = "step-title";
        title.textContent = step.name;
        const detail = document.createElement("div");
        detail.className = "step-detail";
        detail.textContent = step.detail;
        body.append(title, detail);
        item.append(badge, body);
        pipelineBox.append(item);
      }
    }

    runButton.addEventListener("click", async () => {
      runButton.disabled = true;
      copyPromptButton.disabled = true;
      statusBox.textContent = "Running contract assistant...";
      try {
        const response = await fetch("/api/analyze", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            project_path: requestProjectPath(),
            include_main: includeMain.checked,
            extra_args: framacArgsInput.value
          })
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || "Analysis failed");
        statusBox.textContent = data.status;
        renderPipeline(data.pipeline);
        summaryBox.textContent = data.summary;
        promptBox.textContent = data.llm_prompt;
        jsonBox.textContent = JSON.stringify(data.report, null, 2);
        copyPromptButton.disabled = !data.llm_prompt.trim();
      } catch (error) {
        statusBox.textContent = error.message;
        renderPipeline([{status: "error", name: "GUI request", detail: error.message}]);
      } finally {
        runButton.disabled = false;
      }
    });

    async function generateContractDraft() {
      generateDraftButton.disabled = true;
      runWpDraftButton.disabled = true;
      draftBox.value = "";
      statusBox.textContent = "Generating LLM contract draft...";
      try {
        const response = await fetch("/api/llm-suggest", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            project_path: requestProjectPath(),
            include_main: includeMain.checked,
            extra_args: framacArgsInput.value
          })
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || "LLM draft generation failed");
        statusBox.textContent = data.status;
        renderPipeline(data.pipeline);
        promptBox.textContent = data.prompt;
        draftBox.value = JSON.stringify(data.draft, null, 2);
        jsonBox.textContent = JSON.stringify(data, null, 2);
        runWpDraftButton.disabled = !(data.draft && data.draft.suggestions && data.draft.suggestions.length);
        document.querySelector('[data-tab="draft"]').click();
      } catch (error) {
        statusBox.textContent = error.message;
        renderPipeline([{status: "error", name: "Generate LLM draft", detail: error.message}]);
      } finally {
        generateDraftButton.disabled = false;
      }
    }

    async function runFramaC(mode, draft = null) {
      runEvaButton.disabled = true;
      runWpButton.disabled = true;
      runWpDraftButton.disabled = true;
      framacBox.textContent = "";
      statusBox.textContent = `Running Frama-C ${mode.toUpperCase()}...`;
      try {
        const body = {
          mode,
          project_path: requestProjectPath(),
          extra_args: framacArgsInput.value
        };
        if (draft) {
          body.draft = draft;
        }
        const response = await fetch("/api/frama-c", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body)
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || "Frama-C run failed");
        statusBox.textContent = data.status;
        renderPipeline(data.pipeline);
        framacBox.textContent = data.output;
        jsonBox.textContent = JSON.stringify(data, null, 2);
        document.querySelector('[data-tab="framac"]').click();
      } catch (error) {
        statusBox.textContent = error.message;
        renderPipeline([{status: "error", name: "Frama-C request", detail: error.message}]);
      } finally {
        runEvaButton.disabled = false;
        runWpButton.disabled = false;
        runWpDraftButton.disabled = !draftBox.value.trim();
      }
    }

    runEvaButton.addEventListener("click", () => runFramaC("eva"));
    runWpButton.addEventListener("click", () => runFramaC("wp"));
    generateDraftButton.addEventListener("click", () => generateContractDraft());
    runWpDraftButton.addEventListener("click", () => {
      try {
        runFramaC("wp", JSON.parse(draftBox.value));
      } catch (error) {
        statusBox.textContent = "LLM draft is not valid JSON.";
        renderPipeline([{status: "error", name: "Read LLM draft", detail: error.message}]);
      }
    });
    browseProjectPathButton.addEventListener("click", () => browseProjectPath());
    useProjectRootButton.addEventListener("click", () => {
      projectPathInput.value = "/project";
      browseProjectPath("/project");
    });

    copyPromptButton.addEventListener("click", async () => {
      await navigator.clipboard.writeText(promptBox.textContent);
      statusBox.textContent = "LLM prompt copied.";
    });
  </script>
</body>
</html>
"""


def pipeline_for_reports(reports: list[object]) -> list[dict[str, str]]:
    functions = [function for report in reports for function in report.functions]
    contracted = [function for function in functions if function.has_contract]
    missing_helpers = [
        function for report in reports for function in report.missing_helper_contracts
    ]
    backends = sorted(
        {str(getattr(report, "analysis_backend", "source-scan")) for report in reports}
    )
    warnings = [
        str(getattr(report, "analysis_warning"))
        for report in reports
        if getattr(report, "analysis_warning", None)
    ]
    helper_detail = (
        f"{len(missing_helpers)} reachable helper function(s) miss contracts."
        if missing_helpers
        else "No reachable helper functions are missing contracts."
    )
    helper_detail += f" Backend: {', '.join(backends)}."
    if warnings:
        helper_detail += f" Warning: {warnings[0]}"
    return [
        {
            "status": "ok" if functions else "warn",
            "name": "Scan C project",
            "detail": (
                f"Found {len(functions)} function definition(s) "
                f"in {len(reports)} source file(s)."
            ),
        },
        {
            "status": "ok" if contracted else "warn",
            "name": "Detect ACSL contracts",
            "detail": (
                f"{len(contracted)} function(s) have ACSL contracts."
                if contracted
                else "No ACSL contracts found immediately above functions."
            ),
        },
        {
            "status": "warn" if missing_helpers else "ok",
            "name": "Check helper contracts",
            "detail": helper_detail,
        },
        {
            "status": "skip",
            "name": "LLM suggestion",
            "detail": "Prompt is generated for manual LLM use; no API call is made.",
        },
        {
            "status": "skip",
            "name": "Frama-C/WP/Eva validation",
            "detail": "Validation runs only when the Eva or WP button is pressed.",
        },
    ]


def pipeline_for_report(report: object) -> list[dict[str, str]]:
    return pipeline_for_reports([report])


def payload_files(payload: dict[str, object]) -> list[dict[str, str]]:
    files = payload.get("files")
    if isinstance(files, list):
        result = []
        for item in files:
            if not isinstance(item, dict):
                continue
            filename = item.get("filename", "input.c")
            code = item.get("code", "")
            if isinstance(filename, str) and isinstance(code, str):
                result.append({"filename": filename, "code": code})
        if result:
            return result

    filename = payload.get("filename", "input.c")
    code = payload.get("code", "")
    if not isinstance(filename, str) or not isinstance(code, str):
        raise ValueError("C source is empty")
    return [{"filename": filename, "code": code}]


def has_project_path(payload: dict[str, object]) -> bool:
    project_path = payload.get("project_path")
    return isinstance(project_path, str) and bool(project_path.strip())


def list_project_path(project_path: str | None) -> dict[str, object]:
    return list_container_path(project_path, ASSISTANT.SOURCE_SUFFIXES)


def suggest_contracts(
    project_path: str,
    include_main: bool = False,
    extra_args: str | list[str] | None = None,
) -> dict[str, object]:
    root, source_paths = source_paths_from_project_path(project_path, ASSISTANT)
    reports = ASSISTANT.analyze_files(
        source_paths, include_main, extra_args=extra_args, root=root
    )
    return suggest_contracts_from_reports(reports, root, pipeline_for_reports)


def analyze_project(
    files: list[dict[str, str]],
    include_main: bool = False,
    extra_args: str | list[str] | None = None,
) -> dict[str, object]:
    with tempfile.TemporaryDirectory(prefix="autodeduct-contract-assistant-") as tmpdir:
        root = Path(tmpdir)
        written = write_project_files(files, root)
        source_paths = [
            path for path in written if path.suffix.lower() in ASSISTANT.SOURCE_SUFFIXES
        ]
        if not source_paths:
            raise ValueError("No .c or .h source files were provided")
        reports = ASSISTANT.analyze_files(
            source_paths, include_main, extra_args=extra_args, root=root
        )
        text_report = ASSISTANT.format_text_report(reports)
        llm_prompt = ASSISTANT.format_llm_prompt(reports)
        return {
            "status": "Analysis complete.",
            "pipeline": pipeline_for_reports(reports),
            "summary": replace_project_paths(text_report, source_paths, root),
            "llm_prompt": replace_project_paths(llm_prompt, source_paths, root),
            "report": display_reports(reports, root),
        }


def analyze_project_path(
    project_path: str,
    include_main: bool = False,
    extra_args: str | list[str] | None = None,
) -> dict[str, object]:
    root, source_paths = source_paths_from_project_path(project_path, ASSISTANT)
    reports = ASSISTANT.analyze_files(
        source_paths, include_main, extra_args=extra_args, root=root
    )
    text_report = ASSISTANT.format_text_report(reports)
    llm_prompt = ASSISTANT.format_llm_prompt(reports)
    return {
        "status": "Analysis complete.",
        "pipeline": pipeline_for_reports(reports),
        "summary": replace_project_paths(text_report, source_paths, root),
        "llm_prompt": replace_project_paths(llm_prompt, source_paths, root),
        "report": display_reports(reports, root),
    }


def analyze_code(filename: str, code: str, include_main: bool = False) -> dict[str, object]:
    return analyze_project(
        [{"filename": filename or "input.c", "code": code}], include_main
    )


def run_frama_c_project_path(
    project_path: str, mode: str, extra_args: str | list[str] | None = None
) -> dict[str, object]:
    root, source_paths = source_paths_from_project_path(project_path, ASSISTANT)
    c_files = [path for path in source_paths if path.suffix.lower() == ".c"]
    return run_frama_c_on_paths(
        root, c_files, len(source_paths), mode, extra_args, "Use project path"
    )


class ContractAssistantGuiHandler(BaseHTTPRequestHandler):
    server_version = "AutoDeductContractAssistantGUI/0.1"

    def do_GET(self) -> None:
        if self.path not in ("/", "/index.html"):
            self.send_error(HTTPStatus.NOT_FOUND)
            return
        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(HTML_PAGE.encode("utf-8"))))
        self.end_headers()
        self.wfile.write(HTML_PAGE.encode("utf-8"))

    def do_POST(self) -> None:
        if self.path not in (
            "/api/analyze",
            "/api/frama-c",
            "/api/list-path",
            "/api/llm-suggest",
        ):
            self.send_error(HTTPStatus.NOT_FOUND)
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
            payload = json.loads(self.rfile.read(length).decode("utf-8"))
            if self.path == "/api/list-path":
                project_path = payload.get("project_path")
                response = list_project_path(
                    project_path if isinstance(project_path, str) else None
                )
            elif self.path == "/api/llm-suggest":
                include_main = bool(payload.get("include_main", False))
                if not has_project_path(payload):
                    raise ValueError("Project path is required for LLM suggestions")
                response = suggest_contracts(
                    str(payload["project_path"]),
                    include_main,
                    payload.get("extra_args"),
                )
            elif self.path == "/api/analyze":
                include_main = bool(payload.get("include_main", False))
                if has_project_path(payload):
                    response = analyze_project_path(
                        str(payload["project_path"]),
                        include_main,
                        payload.get("extra_args"),
                    )
                else:
                    response = analyze_project(
                        payload_files(payload), include_main, payload.get("extra_args")
                    )
            else:
                mode = str(payload.get("mode", "eva"))
                if has_project_path(payload):
                    draft = payload.get("draft")
                    if draft is not None:
                        response = run_frama_c_project_path_with_draft(
                            str(payload["project_path"]),
                            mode,
                            draft,
                            ASSISTANT,
                            payload.get("extra_args"),
                        )
                    else:
                        response = run_frama_c_project_path(
                            str(payload["project_path"]), mode, payload.get("extra_args")
                        )
                else:
                    response = run_frama_c(
                        payload_files(payload), mode, payload.get("extra_args")
                    )
            self.send_json(response)
        except Exception as exc:
            self.send_json({"error": str(exc)}, status=HTTPStatus.BAD_REQUEST)

    def send_json(self, data: dict[str, object], status: HTTPStatus = HTTPStatus.OK) -> None:
        body = json.dumps(data, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format: str, *args: object) -> None:
        print(f"{self.address_string()} - {format % args}", file=sys.stderr)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run the AutoDeduct contract assistant GUI.")
    parser.add_argument("--host", default="127.0.0.1", help="host interface to bind")
    parser.add_argument("--port", default=8765, type=int, help="port to listen on")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    server = ThreadingHTTPServer((args.host, args.port), ContractAssistantGuiHandler)
    url_host = "localhost" if args.host in ("0.0.0.0", "::") else args.host
    print(f"AutoDeduct contract assistant GUI: http://{url_host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopping AutoDeduct contract assistant GUI.")
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
