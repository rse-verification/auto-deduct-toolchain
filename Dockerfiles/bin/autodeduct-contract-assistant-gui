def pipeline_for_report(report: object) -> list[dict[str, str]]:
    functions = report.functions
    contracted = [function for function in functions if function.has_contract]
    missing_helpers = report.missing_helper_contracts
    return [
        {
            "status": "ok" if functions else "warn",
            "name": "Scan C source",
            "detail": f"Found {len(functions)} function definition(s).",
        },
        {
            "status": "ok" if contracted else "warn",
            "name": "Detect ACSL contracts",
            "detail": (
                f"{len(contracted)} function(s) have ACSL contracts."
                if contracted
                else "No ACSL contracts found immediately above functions."
            ),
        },
        {
            "status": "warn" if missing_helpers else "ok",
            "name": "Check helper contracts",
            "detail": (
                f"{len(missing_helpers)} reachable helper function(s) miss contracts."
                if missing_helpers
                else "No reachable helper functions are missing contracts."
            ),
        },
        {
            "status": "skip",
            "name": "LLM suggestion",
            "detail": "Prompt is generated for manual LLM use; no API call is made.",
        },
        {
            "status": "skip",
            "name": "Frama-C/WP/Eva validation",
            "detail": "Validation is not run by this GUI slice yet.",
        },
    ]


def analyze_code(filename: str, code: str, include_main: bool = False) -> dict[str, object]:
    safe_name = Path(filename or "input.c").name or "input.c"
    with tempfile.TemporaryDirectory(prefix="autodeduct-contract-assistant-") as tmpdir:
        path = Path(tmpdir) / safe_name
        path.write_text(code, encoding="utf-8")
        report = ASSISTANT.analyze_file(path, include_main)
        text_report = ASSISTANT.format_text_report([report])
        llm_prompt = ASSISTANT.format_llm_prompt([report])
        report_json = report.to_json()
        report_json["file"] = safe_name
        return {
            "status": "Analysis complete.",
            "pipeline": pipeline_for_report(report),
            "summary": text_report.replace(str(path), safe_name),
            "llm_prompt": llm_prompt.replace(str(path), safe_name),
            "report": report_json,
        }


class ContractAssistantGuiHandler(BaseHTTPRequestHandler):
    server_version = "AutoDeductContractAssistantGUI/0.1"

    def do_GET(self) -> None:
        if self.path not in ("/", "/index.html"):
            self.send_error(HTTPStatus.NOT_FOUND)
            return
        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(HTML_PAGE.encode("utf-8"))))
        self.end_headers()
        self.wfile.write(HTML_PAGE.encode("utf-8"))

    def do_POST(self) -> None:
        if self.path != "/api/analyze":
            self.send_error(HTTPStatus.NOT_FOUND)
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
            payload = json.loads(self.rfile.read(length).decode("utf-8"))
            code = payload.get("code", "")
            if not isinstance(code, str) or not code.strip():
                raise ValueError("C source is empty")
            filename = payload.get("filename", "input.c")
            include_main = bool(payload.get("include_main", False))
            response = analyze_code(str(filename), code, include_main)
            self.send_json(response)
        except Exception as exc:
            self.send_json({"error": str(exc)}, status=HTTPStatus.BAD_REQUEST)

    def send_json(self, data: dict[str, object], status: HTTPStatus = HTTPStatus.OK) -> None:
        body = json.dumps(data, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format: str, *args: object) -> None:
        print(f"{self.address_string()} - {format % args}", file=sys.stderr)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run the AutoDeduct contract assistant GUI.")
    parser.add_argument("--host", default="127.0.0.1", help="host interface to bind")
    parser.add_argument("--port", default=8765, type=int, help="port to listen on")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    server = ThreadingHTTPServer((args.host, args.port), ContractAssistantGuiHandler)
    url_host = "localhost" if args.host in ("0.0.0.0", "::") else args.host
    print(f"AutoDeduct contract assistant GUI: http://{url_host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopping AutoDeduct contract assistant GUI.")
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
