"""Small browser UI for the AutoDeduct contract assistant."""

from __future__ import annotations

import argparse
import json
import sys
import tempfile
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from importlib.machinery import SourceFileLoader
from importlib.util import module_from_spec, spec_from_loader
from pathlib import Path


def load_assistant_module():
    assistant_path = Path(__file__).with_name("autodeduct-contract-assistant")
    loader = SourceFileLoader("autodeduct_contract_assistant", str(assistant_path))
    spec = spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("Could not load contract assistant module")
    module = module_from_spec(spec)
    sys.modules[loader.name] = module
    loader.exec_module(module)
    return module


ASSISTANT = load_assistant_module()


