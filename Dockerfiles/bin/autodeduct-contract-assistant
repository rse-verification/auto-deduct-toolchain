"""Find C helper functions that are missing ACSL contracts.

This is intentionally conservative. It does not verify or generate contracts.
It prepares a deterministic report, and can emit an LLM-ready prompt for a
human-reviewed contract suggestion workflow.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import tempfile
from dataclasses import dataclass, field
from pathlib import Path


CONTROL_WORDS = {
    "if",
    "for",
    "while",
    "switch",
    "return",
    "sizeof",
    "alignof",
    "_Alignof",
    "_Generic",
}

FUNCTION_DEF_RE = re.compile(
    r"""
    ^[ \t]*
    (?P<signature>
      [A-Za-z_][A-Za-z0-9_\s*]*?
      \b(?P<name>[A-Za-z_][A-Za-z0-9_]*)\s*
      \([^;{}]*\)
    )
    \s*\{
    """,
    re.MULTILINE | re.VERBOSE,
)

CALL_RE = re.compile(r"\b([A-Za-z_][A-Za-z0-9_]*)\s*\(")
SOURCE_SUFFIXES = {".c", ".h"}


@dataclass
class FunctionInfo:
    path: Path
    name: str
    signature: str
    line: int
    start: int
    body_start: int
    end: int
    has_contract: bool
    calls: list[str] = field(default_factory=list)

    def to_json(self) -> dict[str, object]:
        return {
            "name": self.name,
            "signature": " ".join(self.signature.split()),
            "line": self.line,
            "has_contract": self.has_contract,
            "calls": self.calls,
        }


@dataclass
class FileReport:
    path: Path
    functions: list[FunctionInfo]
    missing_contracts: list[FunctionInfo]
    missing_helper_contracts: list[FunctionInfo]
    called_by: dict[str, list[str]]
    analysis_backend: str = "source-scan"
    analysis_warning: str | None = None

    def to_json(self) -> dict[str, object]:
        report = {
            "file": str(self.path),
            "analysis_backend": self.analysis_backend,
            "functions": [function.to_json() for function in self.functions],
            "missing_contracts": [
                function.to_json() for function in self.missing_contracts
            ],
            "missing_helper_contracts": [
                function.to_json() for function in self.missing_helper_contracts
            ],
            "called_by": self.called_by,
        }
        if self.analysis_warning:
            report["analysis_warning"] = self.analysis_warning
        return report


def line_of(text: str, index: int) -> int:
    return text.count("\n", 0, index) + 1


def mask_comments_and_strings(text: str) -> str:
    """Replace comments and strings with spaces while preserving newlines."""
    chars = list(text)
    i = 0
    state = "code"
    while i < len(chars):
        current = chars[i]
        next_char = chars[i + 1] if i + 1 < len(chars) else ""
        if state == "code":
            if current == "/" and next_char == "/":
                chars[i] = chars[i + 1] = " "
                i += 2
                state = "line_comment"
            elif current == "/" and next_char == "*":
                chars[i] = chars[i + 1] = " "
                i += 2
                state = "block_comment"
            elif current == '"':
                chars[i] = " "
                i += 1
                state = "string"
            elif current == "'":
                chars[i] = " "
                i += 1
                state = "char"
            else:
                i += 1
        elif state == "line_comment":
            if current == "\n":
                state = "code"
            else:
                chars[i] = " "
            i += 1
        elif state == "block_comment":
            if current == "\n":
                i += 1
            elif current == "*" and next_char == "/":
                chars[i] = chars[i + 1] = " "
                i += 2
                state = "code"
            else:
                chars[i] = " "
                i += 1
        elif state == "string":
            if current == "\\":
                chars[i] = " "
                if i + 1 < len(chars):
                    chars[i + 1] = " "
                i += 2
            elif current == '"':
                chars[i] = " "
                i += 1
                state = "code"
            else:
                if current != "\n":
                    chars[i] = " "
                i += 1
        elif state == "char":
            if current == "\\":
                chars[i] = " "
                if i + 1 < len(chars):
                    chars[i + 1] = " "
                i += 2
            elif current == "'":
                chars[i] = " "
                i += 1
                state = "code"
            else:
                if current != "\n":
                    chars[i] = " "
                i += 1
    return "".join(chars)


def matching_brace(masked_text: str, open_brace: int) -> int | None:
    depth = 0
    for index in range(open_brace, len(masked_text)):
        if masked_text[index] == "{":
            depth += 1
        elif masked_text[index] == "}":
            depth -= 1
            if depth == 0:
                return index
    return None


def has_acsl_contract_before(text: str, function_start: int) -> bool:
    before = text[:function_start]
    end = len(before.rstrip())
    if end == 0:
        return False

    if before[:end].endswith("*/"):
        block_start = before.rfind("/*@", 0, end)
        if block_start == -1:
            return False
        block_end = before.find("*/", block_start)
        return block_end != -1 and block_end + 2 == end

    lines = before[:end].splitlines()
    saw_acsl_line = False
    for line in reversed(lines):
        stripped = line.strip()
        if not stripped:
            continue
        if stripped.startswith("//@"):
            saw_acsl_line = True
            continue
        break
    return saw_acsl_line


def extract_calls(masked_body: str, known_functions: set[str]) -> list[str]:
    calls: list[str] = []
    for match in CALL_RE.finditer(masked_body):
        name = match.group(1)
        if name in CONTROL_WORDS:
            continue
        if name not in known_functions:
            continue
        if name not in calls:
            calls.append(name)
    return calls


def discover_function_candidates(path: Path, text: str) -> list[FunctionInfo]:
    masked_text = mask_comments_and_strings(text)
    candidates: list[FunctionInfo] = []
    for match in FUNCTION_DEF_RE.finditer(masked_text):
        name = match.group("name")
        if name in CONTROL_WORDS:
            continue
        open_brace = match.end() - 1
        close_brace = matching_brace(masked_text, open_brace)
        if close_brace is None:
            continue
        candidates.append(
            FunctionInfo(
                path=path,
                name=name,
                signature=text[match.start("signature") : match.end("signature")],
                line=line_of(text, match.start("name")),
                start=match.start(),
                body_start=open_brace + 1,
                end=close_brace + 1,
                has_contract=has_acsl_contract_before(text, match.start()),
            )
        )

    return candidates


def populate_calls(functions: list[FunctionInfo], text: str, known_functions: set[str]) -> None:
    masked_text = mask_comments_and_strings(text)
    for function in functions:
        body = masked_text[function.body_start : function.end - 1]
        function.calls = [
            call for call in extract_calls(body, known_functions) if call != function.name
        ]


def discover_functions(path: Path, text: str) -> list[FunctionInfo]:
    candidates = discover_function_candidates(path, text)
    known_functions = {function.name for function in candidates}
    populate_calls(candidates, text, known_functions)
    return candidates


def function_key(function: FunctionInfo) -> tuple[Path, int, str]:
    return (function.path, function.start, function.name)


def functions_by_name(functions: list[FunctionInfo]) -> dict[str, list[FunctionInfo]]:
    by_name: dict[str, list[FunctionInfo]] = {}
    for function in functions:
        by_name.setdefault(function.name, []).append(function)
    return by_name


def resolve_call_targets(
    caller: FunctionInfo, by_name: dict[str, list[FunctionInfo]]
) -> list[FunctionInfo]:
    targets: list[FunctionInfo] = []
    for called in caller.calls:
        candidates = by_name.get(called, [])
        if len(candidates) == 1:
            targets.extend(candidates)
            continue

        same_file = [function for function in candidates if function.path == caller.path]
        if len(same_file) == 1:
            targets.extend(same_file)
    return targets


def append_unique(items: list[str], value: str) -> None:
    if value not in items:
        items.append(value)


def called_by_for(
    report_functions: list[FunctionInfo], all_functions: list[FunctionInfo]
) -> dict[str, list[str]]:
    target_keys = {function_key(function) for function in report_functions}
    called_by: dict[str, list[str]] = {function.name: [] for function in report_functions}
    by_name = functions_by_name(all_functions)
    for caller in all_functions:
        for target in resolve_call_targets(caller, by_name):
            if function_key(target) in target_keys:
                append_unique(called_by.setdefault(target.name, []), caller.name)
    return called_by


def reachable_from_contracted(functions: list[FunctionInfo]) -> set[tuple[Path, int, str]]:
    by_name = functions_by_name(functions)
    reachable: set[tuple[Path, int, str]] = set()
    worklist = [function for function in functions if function.has_contract]
    while worklist:
        current = worklist.pop()
        for target in resolve_call_targets(current, by_name):
            key = function_key(target)
            if key not in reachable:
                reachable.add(key)
                worklist.append(target)
    return reachable


def split_extra_args(extra_args: str | list[str] | None) -> list[str]:
    if extra_args is None:
        return []
    if isinstance(extra_args, list):
        return [str(arg) for arg in extra_args if str(arg)]
    if not extra_args.strip():
        return []
    return shlex.split(extra_args)


def common_source_root(source_paths: list[Path]) -> Path:
    if not source_paths:
        return Path.cwd()
    parents = [str(path.resolve().parent) for path in source_paths]
    return Path(os.path.commonpath(parents))


def compact_command_output(output: str, limit: int = 900) -> str:
    cleaned = output.strip()
    if len(cleaned) <= limit:
        return cleaned
    return cleaned[: limit - 80].rstrip() + "\n... output truncated ..."


def run_isp_missing_helper_report(
    source_paths: list[Path],
    root: Path,
    extra_args: str | list[str] | None = None,
) -> dict[str, object]:
    c_paths = [path for path in source_paths if path.suffix.lower() == ".c"]
    if not c_paths:
        raise RuntimeError("ISP backend needs at least one .c file")

    with tempfile.TemporaryDirectory(prefix="autodeduct-isp-report-") as tmpdir:
        report_path = Path(tmpdir) / "missing-helper-contracts.json"
        command = [
            "frama-c",
            "-autoload-plugins",
            "-isp-missing-helper-contracts-json",
            str(report_path),
            *split_extra_args(extra_args),
            *[str(path.resolve()) for path in c_paths],
        ]
        try:
            result = subprocess.run(
                command,
                cwd=root,
                check=False,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=120,
            )
        except FileNotFoundError as exc:
            raise RuntimeError("frama-c was not found") from exc
        except subprocess.TimeoutExpired as exc:
            output = exc.stdout or ""
            raise RuntimeError(
                "frama-c timed out while generating the ISP missing-helper report"
                + (f": {compact_command_output(output)}" if output else "")
            ) from exc

        if result.returncode != 0:
            output = compact_command_output(result.stdout)
            raise RuntimeError(
                "frama-c could not generate the ISP missing-helper report"
                + (f": {output}" if output else "")
            )
        if not report_path.exists():
            raise RuntimeError("ISP did not write the missing-helper JSON report")

        return json.loads(report_path.read_text(encoding="utf-8"))


def path_matches_isp_file(path: Path, isp_file: object, root: Path) -> bool:
    if not isinstance(isp_file, str) or not isp_file:
        return False

    normalized = isp_file.replace("\\", "/")
    candidates = {
        str(path).replace("\\", "/"),
        str(path.resolve()).replace("\\", "/"),
        path.name,
    }
    try:
        candidates.add(str(path.resolve().relative_to(root.resolve())).replace("\\", "/"))
    except ValueError:
        pass

    return any(candidate == normalized or candidate.endswith("/" + normalized) for candidate in candidates)


def caller_names_from_isp_item(item: dict[str, object]) -> list[str]:
    names: list[str] = []
    callers = item.get("called_by", [])
    if not isinstance(callers, list):
        return names
    for caller in callers:
        if isinstance(caller, dict):
            name = caller.get("function")
            if isinstance(name, str):
                append_unique(names, name)
    return names


def find_isp_report_function(
    reports: list[FileReport], item: dict[str, object], root: Path
) -> tuple[FileReport, FunctionInfo] | None:
    name = item.get("function")
    if not isinstance(name, str):
        return None

    line: int | None = None
    raw_line = item.get("line")
    if isinstance(raw_line, int):
        line = raw_line

    candidates: list[tuple[FileReport, FunctionInfo]] = []
    for report in reports:
        if not path_matches_isp_file(report.path, item.get("file"), root):
            continue
        candidates.extend(
            (report, function)
            for function in report.functions
            if function.name == name
        )

    if line is not None:
        line_matches = [
            (report, function)
            for report, function in candidates
            if function.line == line
        ]
        if len(line_matches) == 1:
            return line_matches[0]

    if len(candidates) == 1:
        return candidates[0]
    return None


def apply_isp_missing_helper_report(
    reports: list[FileReport], isp_report: dict[str, object], root: Path
) -> list[FileReport]:
    raw_missing = isp_report.get("missing_helper_contracts", [])
    if not isinstance(raw_missing, list):
        raise RuntimeError("ISP report has no missing_helper_contracts list")

    matches: list[tuple[FileReport, FunctionInfo, list[str]]] = []
    unmatched: list[str] = []
    for item in raw_missing:
        if not isinstance(item, dict):
            unmatched.append(str(item))
            continue
        match = find_isp_report_function(reports, item, root)
        if match is None:
            unmatched.append(json.dumps(item, sort_keys=True))
            continue
        report, function = match
        matches.append((report, function, caller_names_from_isp_item(item)))

    if unmatched:
        raise RuntimeError(
            "could not map ISP missing-helper report item(s) back to source scan: "
            + "; ".join(unmatched)
        )

    for report in reports:
        report.missing_helper_contracts = []
        report.analysis_backend = "isp-frama-c"
        report.analysis_warning = None

    for report, function, callers in matches:
        if function not in report.missing_helper_contracts:
            report.missing_helper_contracts.append(function)
        report.called_by[function.name] = callers

    return reports


def analyze_file(path: Path, include_main: bool) -> FileReport:
    text = path.read_text(encoding="utf-8")
    functions = discover_functions(path, text)
    called_by = called_by_for(functions, functions)

    missing_contracts = [
        function
        for function in functions
        if not function.has_contract and (include_main or function.name != "main")
    ]

    reachable = reachable_from_contracted(functions)
    missing_helper_contracts = [
        function
        for function in missing_contracts
        if function_key(function) in reachable and (include_main or function.name != "main")
    ]

    return FileReport(
        path=path,
        functions=functions,
        missing_contracts=missing_contracts,
        missing_helper_contracts=missing_helper_contracts,
        called_by=called_by,
    )


def collect_source_paths(paths: list[Path]) -> list[Path]:
    source_paths: list[Path] = []
    for path in paths:
        if path.is_dir():
            for child in sorted(path.rglob("*")):
                if child.is_file() and child.suffix.lower() in SOURCE_SUFFIXES:
                    source_paths.append(child)
        elif path.is_file():
            source_paths.append(path)
        else:
            raise FileNotFoundError(path)
    return source_paths


def analyze_files_source_scan(paths: list[Path], include_main: bool) -> list[FileReport]:
    source_paths = collect_source_paths(paths)
    texts = {path: path.read_text(encoding="utf-8") for path in source_paths}
    functions_by_path = {
        path: discover_function_candidates(path, text) for path, text in texts.items()
    }
    all_functions = [
        function for functions in functions_by_path.values() for function in functions
    ]
    known_functions = {function.name for function in all_functions}
    for path, functions in functions_by_path.items():
        populate_calls(functions, texts[path], known_functions)

    reachable = reachable_from_contracted(all_functions)
    reports: list[FileReport] = []
    for path, functions in functions_by_path.items():
        called_by = called_by_for(functions, all_functions)
        missing_contracts = [
            function
            for function in functions
            if not function.has_contract and (include_main or function.name != "main")
        ]
        missing_helper_contracts = [
            function
            for function in missing_contracts
            if function_key(function) in reachable and (include_main or function.name != "main")
        ]
        reports.append(
            FileReport(
                path=path,
                functions=functions,
                missing_contracts=missing_contracts,
                missing_helper_contracts=missing_helper_contracts,
                called_by=called_by,
            )
        )
    return reports


def analyze_files(
    paths: list[Path],
    include_main: bool,
    backend: str = "auto",
    extra_args: str | list[str] | None = None,
    root: Path | None = None,
) -> list[FileReport]:
    source_paths = collect_source_paths(paths)
    reports = analyze_files_source_scan(source_paths, include_main)
    if backend == "source":
        return reports

    analysis_root = root or common_source_root(source_paths)
    try:
        isp_report = run_isp_missing_helper_report(
            source_paths, analysis_root, extra_args
        )
        return apply_isp_missing_helper_report(reports, isp_report, analysis_root)
    except RuntimeError as exc:
        if backend == "isp":
            raise
        warning = f"ISP/Frama-C backend unavailable; using source scan: {exc}"
        for report in reports:
            report.analysis_backend = "source-scan"
            report.analysis_warning = warning
        return reports


def format_text_report(reports: list[FileReport]) -> str:
    lines: list[str] = ["AutoDeduct contract assistant report", ""]
    for report in reports:
        lines.append(f"File: {report.path}")
        lines.append(f"  Analysis backend: {report.analysis_backend}")
        if report.analysis_warning:
            lines.append(f"  Analysis warning: {report.analysis_warning}")
        lines.append(f"  Functions found: {len(report.functions)}")
        contracted = [function.name for function in report.functions if function.has_contract]
        lines.append(
            "  Functions with ACSL contracts: "
            + (", ".join(contracted) if contracted else "none")
        )
        if report.missing_helper_contracts:
            lines.append("  Missing helper contracts:")
            for function in report.missing_helper_contracts:
                callers = ", ".join(report.called_by.get(function.name, [])) or "unknown"
                lines.append(
                    f"    - {function.name} at line {function.line} "
                    f"(called by: {callers})"
                )
        else:
            lines.append("  Missing helper contracts: none")
        lines.append("")
    lines.append(
        "Use --llm-prompt FILE to write a prompt for contract suggestions. "
        "Treat suggestions as drafts and verify them with Frama-C/WP."
    )
    return "\n".join(lines)


def format_llm_prompt(reports: list[FileReport]) -> str:
    sections = [
        "You are helping draft ACSL contracts for C helper functions.",
        "Generate candidate contracts only for the listed missing helper functions.",
        "Do not claim the contracts are verified. Prefer conservative contracts.",
        "Mention assumptions and cases where the code is too complex.",
        "The contracts will be checked later with Frama-C/WP/Eva.",
        "",
    ]
    for report in reports:
        text = report.path.read_text(encoding="utf-8")
        if not report.missing_helper_contracts:
            continue
        sections.append(f"File: {report.path}")
        for function in report.missing_helper_contracts:
            callers = ", ".join(report.called_by.get(function.name, [])) or "unknown"
            sections.append("")
            sections.append(f"Missing helper function: {function.name}")
            sections.append(f"Line: {function.line}")
            sections.append(f"Called by: {callers}")
            sections.append("Function code:")
            sections.append("```c")
            sections.append(text[function.start : function.end].strip())
            sections.append("```")
        sections.append("")
    if len(sections) <= 6:
        sections.append("No missing helper contracts were found.")
    return "\n".join(sections).rstrip() + "\n"


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Detect C helper functions that are missing ACSL contracts."
    )
    parser.add_argument(
        "files",
        nargs="+",
        type=Path,
        help="C source files or directories to scan recursively",
    )
    parser.add_argument(
        "--include-main",
        action="store_true",
        help="include main when reporting functions missing contracts",
    )
    parser.add_argument(
        "--backend",
        choices=("auto", "source", "isp"),
        default="auto",
        help=(
            "missing-helper backend: auto prefers ISP/Frama-C and falls back to "
            "the source scan, source uses only the built-in scanner, isp requires "
            "the ISP JSON report"
        ),
    )
    parser.add_argument(
        "--frama-c-extra-args",
        default=None,
        metavar="ARGS",
        help=(
            "extra Frama-C options for the ISP backend, for example "
            "'-cpp-extra-args=\"-D__GNUC__=12 -Ioriginal\"'"
        ),
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="print a machine-readable JSON report",
    )
    parser.add_argument(
        "--llm-prompt",
        type=Path,
        metavar="FILE",
        help="write an LLM-ready prompt for the missing helper contracts",
    )
    parser.add_argument(
        "--fail-on-missing",
        action="store_true",
        help="exit with status 1 when missing helper contracts are found",
    )
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    reports = analyze_files(
        args.files,
        args.include_main,
        backend=args.backend,
        extra_args=args.frama_c_extra_args,
    )

    if args.llm_prompt is not None:
        args.llm_prompt.write_text(format_llm_prompt(reports), encoding="utf-8")

    if args.json:
        print(json.dumps([report.to_json() for report in reports], indent=2))
    else:
        print(format_text_report(reports))

    missing = any(report.missing_helper_contracts for report in reports)
    if missing and args.fail_on_missing:
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
